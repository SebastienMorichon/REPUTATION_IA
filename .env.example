# --- Database ---
POSTGRES_USER=reputation
POSTGRES_PASSWORD=reputation
POSTGRES_DB=reputation
DATABASE_URL=postgresql+psycopg://reputation:reputation@localhost:5432/reputation

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT auth ---
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# --- LLM providers (enable/disable independently) ---
OPENAI_API_KEY=
OPENAI_ENABLED=false
OPENAI_DEFAULT_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_ENABLED=true
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# Which provider to use for the ANALYZER stage (extraction of mentions).
# "anthropic" or "openai". Must be enabled above.
ANALYZER_PROVIDER=anthropic
ANALYZER_MODEL=claude-sonnet-4-6

# --- CORS / web ---
WEB_ORIGIN=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
